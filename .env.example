# Oeffentliche Adresse der go2rtc-Bridge (Cloudflare-Tunnel-Hostname).
# Ohne abschliessenden Slash.
NEXT_PUBLIC_GO2RTC_URL=https://stallwache.example.com

# Name des Hauptkamera-Streams (Stallwache) in bridge/go2rtc.yaml (Default: stallwache)
NEXT_PUBLIC_STREAM_NAME=stallwache

# Name des Zweitkamera-Streams (Futterwache) in bridge/go2rtc.yaml (Default: futterwache)
NEXT_PUBLIC_STREAM_NAME_FUTTERWACHE=futterwache
