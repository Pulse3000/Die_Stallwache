# Oeffentliche Adresse der Bridge (Cloudflare-Tunnel-Hostname).
# Ohne abschliessenden Slash. (Alt-Name NEXT_PUBLIC_GO2RTC_URL funktioniert
# weiterhin als Alias.)
NEXT_PUBLIC_BRIDGE_URL=https://stallwache.example.com

# Welche Bridge-Software laeuft dahinter? "go2rtc" (Default) oder "mediamtx".
# Entscheidungshilfe: bridge/README.md
NEXT_PUBLIC_BRIDGE_TYPE=go2rtc

# Stream/Pfad der Hauptkamera "Stallwache" (Default: stallwache)
NEXT_PUBLIC_STREAM_NAME=stallwache

# Stream/Pfad der Zweitkamera "Futterwache" (Default: futterwache)
NEXT_PUBLIC_STREAM_NAME_2=futterwache

# Stream/Pfad der Drittkamera "Stallbox" (Default: stallbox)
NEXT_PUBLIC_STREAM_NAME_3=stallbox

# Futterwache/Stallbox als Hauptbild ueber die Tuya-Cloud (mit Bridge-Fallback).
# Standardmaessig aktiv; auf 0 setzen, um die jeweilige Kamera rein ueber die
# Bridge laufen zu lassen (dann wird deren TUYA_DEVICE_ID_* ignoriert).
NEXT_PUBLIC_FUTTERWACHE_TUYA=1
NEXT_PUBLIC_STALLBOX_TUYA=1

# --- Tuya-Cloud - NUR serverseitig in Vercel setzen, nie NEXT_PUBLIC! ---
# Ein Access-ID/Secret-Paar gilt fuers ganze Tuya-Cloud-Projekt; jede Kamera
# bekommt ihre eigene Geraete-ID.
# TUYA_ACCESS_ID=
# TUYA_ACCESS_SECRET=
# TUYA_DEVICE_ID_FUTTERWACHE=
# TUYA_DEVICE_ID_STALLBOX=
# TUYA_API_BASE=https://openapi.tuyaeu.com

# --- Passwortschutz (optional) - NUR serverseitig, nie NEXT_PUBLIC! ---
# Setzen aktiviert den Login-Schutz fuer die gesamte App (ein gemeinsames
# Passwort). Leer/ungesetzt = App bleibt offen.
# STALLBLICK_PASSWORT=
# Optionaler Signaturschluessel fuer das Session-Cookie (Default: Passwort).
# Eigenen Wert setzen, damit Sessions nicht bei Passwortwechsel-Logik brechen.
# STALLBLICK_AUTH_SECRET=

# --- Edge-Agent-Ingest fuer die KI-Wache (POST /api/events) ---
# EDGE_INGEST_TOKEN=
