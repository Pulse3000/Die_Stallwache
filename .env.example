# Oeffentliche Adresse der go2rtc-Bridge (Cloudflare-Tunnel-Hostname).
# Ohne abschliessenden Slash.
NEXT_PUBLIC_GO2RTC_URL=https://stallwache.example.com

# Stream der Hauptkamera "Stallwache" in bridge/go2rtc.yaml (Default: stallwache)
NEXT_PUBLIC_STREAM_NAME=stallwache

# Stream der Zweitkamera "Futterwache" in bridge/go2rtc.yaml (Default: futterwache)
NEXT_PUBLIC_STREAM_NAME_2=futterwache

# Futterwache als Hauptbild ueber die Tuya-Cloud (mit go2rtc-Fallback).
# Standardmaessig aktiv; auf 0 setzen, um die Futterwache rein ueber go2rtc
# laufen zu lassen (dann werden die TUYA_*-Variablen unten ignoriert).
NEXT_PUBLIC_FUTTERWACHE_TUYA=1

# --- Tuya-Cloud (Futterwache) - NUR serverseitig in Vercel setzen, nie NEXT_PUBLIC! ---
# TUYA_ACCESS_ID=
# TUYA_ACCESS_SECRET=
# TUYA_DEVICE_ID=
# TUYA_API_BASE=https://openapi.tuyaeu.com
